[
    {
        "type": "multiserver",
        "localaddr": ":12345",
        "obfs": true,
        "obfsmethod": "http",
        "obfshost": ["www.bing.com"],
        "backends": [
            {
                "password": "password-for-user1",
                "method": "aes-256-gcm"
            },
            {
                "method": "chacha20-ietf-poly1305",
                "password": "password-for-user2"
            }
        ]
    },
    {
        "type": "local",
        "localaddr": ":1234",
        "remoteaddr": "server.example.com:12345",
        "obfs": true,
        "obfsmethod": "http",
        "password": "password-for-user1",
        "method": "aes-256-gcm",
        "obfshost": ["www.bing.com"]
    },
    {
        "type": "socksproxy",
        "localaddr": ":1233",
        "backends": [
            {
                "remoteaddr": "server.example.com:12345",
                "method": "chacha20-ietf-poly1305",
                "password": "password-for-user2",
                "obfs": true,
                "obfsmethod": "tls",
                "obfshost": ["www.bing.com"]
            },
            {
                "remoteaddr": "server2.example.com:8080",
                "method": "aes-256-gcm",
                "password": "another-password"
            }
        ]
    }
]
